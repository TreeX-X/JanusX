{
  "name": "janusx",
  "version": "0.5.0",
  "type": "module",
  "description": "CLI 工作区管理器 - 统一管理多个 AI 编程助手",
  "main": "out/main/index.js",
  "author": "Tree",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:llm-core && electron-vite dev",
    "build": "npm run build:llm-core && electron-vite build",
    "build:llm-core": "npm run build --workspace=@janusx/llm-core",
    "preview": "electron-vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:llm-core": "npm test --workspace=@janusx/llm-core",
    "models:update:openrouter": "node scripts/update-openrouter-model-registry.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:llm-core": "npm run typecheck --workspace=@janusx/llm-core",
    "lint": "eslint src --ext .ts,.tsx",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.1",
    "ai": "^3.4.33",
    "execa": "^9.0.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.16",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
