{
  "name": "@janusx/llm-core",
  "version": "0.1.0",
  "type": "module",
  "description": "JanusX LLM 核心抽象层 - 统一 Provider 管理",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./model-registry": {
      "types": "./dist/registry/model-registry.d.ts",
      "import": "./dist/registry/model-registry.js",
      "require": "./dist/registry/model-registry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "ai",
    "provider",
    "vertex-ai",
    "openai"
  ],
  "author": "Tree",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google-vertex": "^4.0.147",
    "@ai-sdk/openai": "^3.0.71",
    "ai": "^3.4.33",
    "google-auth-library": "^10.7.0",
    "proxy-agent": "^8.0.2",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
